# Flutter web → nginx. Render sets API_BASE_URL as env (also available as build ARG).
ARG API_BASE_URL=https://fashionai-api.onrender.com
# Must satisfy Dart SDK in pubspec (see pubspec.lock sdks). Pin a tag from:
# https://github.com/cirruslabs/docker-images-flutter/pkgs/container/flutter
FROM ghcr.io/cirruslabs/flutter:3.35.0 AS build
ARG API_BASE_URL
WORKDIR /app
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get
COPY . .
RUN flutter build web --release --dart-define=API_BASE_URL=${API_BASE_URL}

FROM nginx:1.27-alpine
COPY --from=build /app/build/web /usr/share/nginx/html
COPY render/nginx-site.conf /tmp/nginx-site.conf
COPY render/docker-entrypoint-web.sh /docker-entrypoint-web.sh
RUN chmod +x /docker-entrypoint-web.sh
ENV PORT=10000
EXPOSE 10000
ENTRYPOINT ["/docker-entrypoint-web.sh"]
