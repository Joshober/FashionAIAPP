# Flutter web → nginx. Render sets API_BASE_URL as env (also available as build ARG).
ARG API_BASE_URL=https://fashionai-api-6w7k.onrender.com
# Use `stable` so Render always pulls a published SDK (pin a version tag if you need reproducibility).
FROM ghcr.io/cirruslabs/flutter:stable AS build
ARG API_BASE_URL
WORKDIR /app
# Resolve from pubspec.yaml only: a broken or stale pubspec.lock in the repo
# would otherwise fail `pub get` before the full source tree is available.
COPY pubspec.yaml ./
RUN flutter pub get
COPY . .
# Re-resolve after full tree copy so a stale/out-of-sync pubspec.lock from the repo
# cannot leave .dart_tool out of sync before compile.
RUN flutter pub get && flutter build web --release --dart-define=API_BASE_URL=${API_BASE_URL}

FROM nginx:1.27-alpine
COPY --from=build /app/build/web /usr/share/nginx/html
COPY render/nginx-site.conf /etc/nginx-site.conf.tmpl
COPY render/docker-entrypoint-web.sh /docker-entrypoint-web.sh
RUN chmod +x /docker-entrypoint-web.sh
ENV PORT=10000
EXPOSE 10000
ENTRYPOINT ["/docker-entrypoint-web.sh"]
