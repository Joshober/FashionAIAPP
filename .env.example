# --- Backend (also copy values you need into backend/.env or export before `npm run dev`) ---
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/fashion_ai
# MONGODB_DB_NAME=

# Comma-separated; * allowed for host wildcards (e.g. Flutter web dev)
ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# HS256 tokens from POST /api/auth/signin. When set, app-issued JWTs are verified; Auth0 (optional) still overrides when AUTH0_DOMAIN+AUDIENCE are set.
JWT_SECRET=change-me-in-dev
# Optional fixed credentials; if both unset, any email + password (min 4 chars) works for local dev.
SIMPLE_AUTH_EMAIL=
SIMPLE_AUTH_PASSWORD=

ML_SERVICE_URL=https://alvaro05-vit-fashion-api.hf.space
# ML_VIT_SERVICE_URL=https://alvaro05-vit-fashion-api.hf.space

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_AUDIO_MODEL=openai/gpt-audio-mini
OPENROUTER_STT_MODEL=openai/gpt-4o-audio-preview
OPENROUTER_TTS_VOICE=alloy
OPENROUTER_TTS_FORMAT=wav

MAX_AUDIO_BASE64_CHARS=8000000
MAX_TTS_CHARS=2000
MAX_VIT_BASE64_PAYLOAD_CHARS=12000000
# PRENDAS_MAX_PER_USER=200

# --- Flutter (public values only; use --dart-define or .env for non-secrets) ---
API_BASE_URL=http://10.0.2.2:4000
